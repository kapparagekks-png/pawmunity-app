{
  "name": "pawmunity",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"npm run dev -w server\" \"npm run dev -w client\"",
    "server": "npm run dev -w server",
    "client": "npm run dev -w client",
    "build": "npm run build -w client",
    "start": "node server/server.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
